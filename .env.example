# Database settings
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=wishlist

# Application settings
APP_PORT=8080

# JWT settings
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY_HOURS=24

# CORS / CSRF settings
# Comma-separated list of allowed origins for CORS and CSRF trust.
# Use "*" only for development; production must list specific origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080